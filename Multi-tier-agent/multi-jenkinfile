pipeline {
    agent any

    stages {
        stage('Backend Build & Deploy') {
            agent {
                docker { image 'python:3.9' }
            }
            steps {
                echo 'Building Backend...'
                sh '''
                    pip install -r requirements.txt || true
                    python manage.py test || echo "No backend tests found"
                    docker build -t myorg/backend:latest .
                    docker push myorg/backend:latest || echo "Skipping push"
                '''
            }
        }

        stage('Frontend Build & Deploy') {
            agent {
                docker { image 'node:18' }
            }
            steps {
                echo 'Building Frontend...'
                sh '''
                    npm install || true
                    npm run build || echo "No frontend build found"
                    docker build -t myorg/frontend:latest .
                    docker push myorg/frontend:latest || echo "Skipping push"
                '''
            }
        }

        stage('Database Setup') {
            agent {
                docker { image 'postgres:14' }
            }
            steps {
                echo 'Setting up Database...'
                sh '''
                    docker run -d --name mydb \
                        -e POSTGRES_USER=admin \
                        -e POSTGRES_PASSWORD=secret \
                        -e POSTGRES_DB=myapp \
                        postgres:14
                '''
            }
        }

        stage('Integration Test') {
            agent any
            steps {
                echo 'Running Integration Tests...'
                sh '''
                    echo "Pretend to test frontend-backend-database integration"
                '''
            }
        }
    }

    post {
        success {
            echo 'Three-tier pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}

